# .env.example
# -------------
# LegacyLens — RAG System for Legacy Enterprise Codebases
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Embedding API ──────────────────────────────────────────────────────────────
# Voyage AI key for voyage-code-2 embeddings (https://www.voyageai.com)
VOYAGE_API_KEY=your_voyage_api_key_here

# ── LLM API ───────────────────────────────────────────────────────────────────
# OpenAI key for GPT-4o-mini answer generation (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# ── Target repository (pinned fork) ───────────────────────────────────────────
# GitHub owner of your fork of the target codebase (e.g. your GitHub username)
REPO_OWNER=your_github_username

# Repository name of the forked target codebase
REPO_NAME=opencobol-contrib

# Specific commit SHA to pin deep links against — must match the commit
# that was ingested into ChromaDB so file:line links remain stable
REPO_COMMIT=abc123def456789abcdef0123456789abcdef01

# ── Vector database ────────────────────────────────────────────────────────────
# Local or mounted path where ChromaDB persists data between restarts.
# On Railway: set this to a path on a mounted volume so data survives redeploys.
CHROMA_PERSIST_DIR=./chroma_db
